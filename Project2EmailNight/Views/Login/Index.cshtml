@model Project2EmailNight.Dtos.UserLoginDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login</title>

    <!-- CSS -->
    <link rel="icon" href="/vertical/assets/images/favicon-32x32.png" />
    <link href="/vertical/assets/css/pace.min.css" rel="stylesheet" />
    <link href="/vertical/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/vertical/assets/css/icons.css" rel="stylesheet" />
    <link href="/vertical/assets/css/app.css" rel="stylesheet" />
</head>

<body class="bg-login">

    <div class="wrapper">
        <div class="section-authentication-login d-flex align-items-center justify-content-center mt-4">
            <div class="row">
                <div class="col-12 col-lg-8 mx-auto">
                    <div class="card radius-15 overflow-hidden">
                        <div class="row g-0">

                            <!-- FORM -->
                            <div class="col-xl-6">
                                <div class="card-body p-5">

                                    <div class="text-center">
                                        <img src="/vertical/assets/images/logo-icon.png" width="80" />
                                        <h3 class="mt-4">Welcome Back</h3>
                                    </div>

                                    <!-- 🔥 HATA MESAJLARI -->
                                    @foreach (var item in ViewData.ModelState.Values)
                                    {
                                        foreach (var error in item.Errors)
                                        {
                                            <div class="alert alert-danger">@error.ErrorMessage</div>
                                        }
                                    }

                                    <div class="form-body mt-3">
                                        <form method="post" class="row g-3">

                                            <div class="col-12">
                                                <label class="form-label">Username</label>
                                                <input type="text" class="form-control" asp-for="Username" placeholder="Kullanıcı adı" required>
                                                </div>

                                                <div class="col-12">
                                                    <label class="form-label">Password</label>
                                                    <div class="input-group" id="show_hide_password">
                                                        <input type="password" class="form-control border-end-0" asp-for="Password" placeholder="Şifre" required>
                                                            <a href="javascript:;" class="input-group-text bg-transparent">
                                                                <i class="bx bx-hide"></i>
                                                            </a>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-6">
                                                        <div class="form-check form-switch">
                                                            <input class="form-check-input" type="checkbox">
                                                            <label class="form-check-label">Remember Me</label>
                                                        </div>
                                                    </div>

                                                    <div class="col-md-6 text-end">
                                                        <a href="#">Forgot Password?</a>
                                                    </div>

                                                    <div class="col-12">
                                                        <div class="d-grid">
                                                            <button type="submit" class="btn btn-primary">
                                                                <i class="bx bxs-lock-open"></i> Sign in
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <div class="col-12 text-center">
                                                        <p>
                                                            Hesabın yok mu?
                                                            <a href="/Register/Index">Kayıt ol</a>
                                                        </p>
                                                    </div>

                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- SAĞ RESİM -->
                                    <div class="col-xl-6 bg-login-color d-flex align-items-center justify-content-center">
                                        <img src="/vertical/assets/images/login-images/login-frent-img.jpg" class="img-fluid" />
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- JS -->
            <script src="/vertical/assets/js/jquery.min.js"></script>
            <script src="/vertical/assets/js/bootstrap.bundle.min.js"></script>

            <script>
                $(document).ready(function () {
                $("#show_hide_password a").on('click', function (event) {
                event.preventDefault();
                let input = $('#show_hide_password input');
                if (input.attr("type") === "text") {
                input.attr('type', 'password');
                } else {
                input.attr('type', 'text');
                }
                });
                });
            </script>

        </body>
    </html>