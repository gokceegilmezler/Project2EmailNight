@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Syndash Dashboard</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', system-ui, sans-serif; }
        body { background: #f4f5f7; min-height: 100vh; display: flex; flex-direction: column; }

        /* ── NAVBAR ── */
        .navbar {
            display: flex; align-items: center;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 0 20px; height: 58px; gap: 14px;
            position: sticky; top: 0; z-index: 100;
        }
        .brand {
            display: flex; align-items: center; gap: 9px;
            font-size: 18px; font-weight: 600; color: #7c5cbf;
            width: 210px; flex-shrink: 0; text-decoration: none;
        }
        .brand svg { flex-shrink: 0; }
        .hamburger { cursor: pointer; color: #6b7280; flex-shrink: 0; }
        .searchbox {
            flex: 1; max-width: 580px;
            display: flex; align-items: center;
            background: #f4f5f7; border: 1px solid #e5e7eb;
            border-radius: 8px; padding: 0 12px; gap: 8px; height: 36px;
        }
        .searchbox input {
            border: none; background: transparent; outline: none;
            font-size: 13px; color: #111; width: 100%;
        }
        .searchbox input::placeholder { color: #9ca3af; }
        .nav-right { display: flex; align-items: center; gap: 10px; margin-left: auto; }
        .icon-btn {
            position: relative; width: 36px; height: 36px; border-radius: 50%;
            background: #f4f5f7; border: 1px solid #e5e7eb;
            display: flex; align-items: center; justify-content: center; cursor: pointer;
            transition: background 0.15s;
        }
        .icon-btn:hover { background: #ede9f7; }
        .icon-btn svg { width: 15px; height: 15px; color: #6b7280; }
        .badge {
            position: absolute; top: -3px; right: -3px;
            background: #e24b4a; color: #fff;
            font-size: 9px; font-weight: 600; border-radius: 10px;
            padding: 1px 5px; line-height: 1.4; min-width: 16px; text-align: center;
        }
        .user-block { display: flex; align-items: center; gap: 9px; }
        .avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: #7c5cbf; color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; flex-shrink: 0;
        }
        .user-info { display: flex; flex-direction: column; }
        .user-name { font-size: 13px; font-weight: 600; color: #111; white-space: nowrap; }
        .user-status { font-size: 11px; color: #22b573; display: flex; align-items: center; gap: 3px; }
        .user-status::before { content: ''; width: 6px; height: 6px; background: #22b573; border-radius: 50%; }
        .lang { display: flex; align-items: center; gap: 5px; font-size: 12px; color: #6b7280; }

        /* ── LAYOUT ── */
        .layout { display: flex; flex: 1; }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 210px; background: #fff;
            border-right: 1px solid #e5e7eb;
            padding: 16px 12px;
            display: flex; flex-direction: column; gap: 2px;
            flex-shrink: 0;
        }
        .new-msg-btn {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            background: #7c5cbf; color: #fff;
            border: none; border-radius: 8px;
            padding: 10px 14px; font-size: 13px; font-weight: 600;
            cursor: pointer; margin-bottom: 12px; width: 100%;
            transition: background 0.15s;
        }
        .new-msg-btn:hover { background: #6a4db0; }
        .new-msg-btn svg { width: 14px; height: 14px; }
        .section-label {
            font-size: 10px; font-weight: 600; color: #9ca3af;
            text-transform: uppercase; letter-spacing: 0.08em;
            padding: 8px 8px 3px;
        }
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 10px; border-radius: 8px; cursor: pointer;
            font-size: 13px; color: #6b7280; transition: background 0.15s;
            text-decoration: none;
        }
        .nav-item:hover { background: #f4f5f7; color: #6b7280; }
        .nav-item.active { background: #f0ebfb; color: #7c5cbf; font-weight: 600; }
        .nav-item svg { width: 14px; height: 14px; flex-shrink: 0; }
        .nav-item .count {
            margin-left: auto; font-size: 10px; font-weight: 500;
            background: #f4f5f7; padding: 1px 7px; border-radius: 10px; color: #6b7280;
        }
        .nav-item.active .count { background: #e0d3f7; color: #7c5cbf; }
        .divider { height: 1px; background: #f0f0f0; margin: 6px 0; }

        /* ── CONTENT ── */
        .content { flex: 1; padding: 20px; overflow-y: auto; min-width: 0; }

        /* ── STAT CARDS ── */
        .stats-grid {
            display: grid; grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px; margin-bottom: 20px;
        }
        .stat-card { border-radius: 10px; padding: 16px 18px; color: #fff; }
        .stat-card.purple { background: #7c5cbf; }
        .stat-card.blue   { background: #2979d4; }
        .stat-card.pink   { background: #d44f8e; }
        .stat-card.orange { background: #e8813a; }
        .stat-top { display: flex; justify-content: space-between; align-items: flex-start; }
        .stat-num { font-size: 26px; font-weight: 700; line-height: 1; }
        .stat-num sup { font-size: 13px; font-weight: 500; }
        .stat-label { font-size: 12px; opacity: 0.9; margin-top: 4px; }
        .stat-change { font-size: 12px; opacity: 0.85; margin-top: 8px; }
        .stat-icon {
            width: 36px; height: 36px;
            background: rgba(255,255,255,0.2); border-radius: 8px;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .stat-icon svg { width: 18px; height: 18px; color: #fff; }

        /* ── CHART CARD ── */
        .chart-card {
            background: #fff; border: 1px solid #e5e7eb;
            border-radius: 12px; padding: 18px 20px;
        }
        .chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
        .chart-title { font-size: 15px; font-weight: 600; color: #111; }
        .chart-tabs { display: flex; gap: 4px; }
        .tab {
            font-size: 12px; padding: 4px 12px;
            border-radius: 7px; border: 1px solid #e5e7eb;
            background: #f4f5f7; color: #6b7280; cursor: pointer;
            transition: all 0.15s;
        }
        .tab:hover { background: #ede9f7; color: #7c5cbf; }
        .tab.active { background: #7c5cbf; color: #fff; border-color: #7c5cbf; }
        .chart-legend { display: flex; gap: 16px; margin-bottom: 12px; }
        .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #6b7280; }
        .legend-dot { width: 10px; height: 10px; border-radius: 50%; }
        .chart-container { position: relative; height: 260px; }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <a class="brand" href="#">
            <svg width="28" height="28" viewBox="0 0 28 28">
                <circle cx="14" cy="14" r="14" fill="#7c5cbf" />
                <rect x="6" y="10" width="16" height="10" rx="1.5" fill="none" stroke="#fff" stroke-width="1.5" />
                <polyline points="6,11 14,17 22,11" fill="none" stroke="#fff" stroke-width="1.5" />
            </svg>
            Syndash
        </a>

        <div class="hamburger">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
        </div>

        <div class="searchbox">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            <input type="text" placeholder="search" />
        </div>

        <div class="nav-right">
            <div class="icon-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
                <span class="badge">5</span>
            </div>
            <div class="icon-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
                <span class="badge">3</span>
            </div>
            <div class="icon-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M20 21a8 8 0 1 0-16 0" />
                </svg>
            </div>

            <div class="user-block">
                <div class="avatar">JD</div>
                <div class="user-info">
                    <span class="user-name">Jessica Doe</span>
                    <span class="user-status">Available</span>
                </div>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
                    <polyline points="6 9 12 15 18 9" />
                </svg>
            </div>

            <!-- Türk Bayrağı -->
            <div class="lang">
                <svg width="26" height="17" viewBox="0 0 30 20">
                    <rect width="30" height="20" fill="#E30A17" />
                    <circle cx="11" cy="10" r="6" fill="#fff" />
                    <circle cx="13" cy="10" r="4.8" fill="#E30A17" />
                    <polygon points="18,7 18.6,9 20.6,9 19,10.2 19.6,12.2 18,11 16.4,12.2 17,10.2 15.4,9 17.4,9" fill="#fff" />
                </svg>
                TR
            </div>
        </div>
    </nav>

    <!-- LAYOUT -->
    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <button class="new-msg-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Yeni Mesaj
            </button>

            <a class="nav-item active" href="/Dashboard">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
                Dashboard
            </a>

            <div class="divider"></div>
            <div class="section-label">Posta Kutusu</div>

            <a class="nav-item" href="/Message/Inbox">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
                Gelen Kutusu
                <span class="count">24</span>
            </a>
            <a class="nav-item" href="/Message/Sent">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13" />
                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                </svg>
                Giden Kutusu
                <span class="count">8</span>
            </a>
            <a class="nav-item" href="/Message/Starred">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
                Yıldızlı
                <span class="count">5</span>
            </a>
            <a class="nav-item" href="/Message/Spam">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="4.93" y1="4.93" x2="19.07" y2="19.07" />
                </svg>
                Spam
                <span class="count">12</span>
            </a>
            <a class="nav-item" href="/Message/Drafts">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Taslak
                <span class="count">3</span>
            </a>
            <a class="nav-item" href="/Message/Trash">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6l-1 14H6L5 6" />
                    <path d="M10 11v6" />
                    <path d="M14 11v6" />
                    <path d="M9 6V4h6v2" />
                </svg>
                Çöp Kutusu
            </a>

            <div class="divider"></div>
            <div class="section-label">Web Apps</div>

            <a class="nav-item" href="/Email">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                </svg>
                Email
            </a>
            <a class="nav-item" href="/Chat">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                </svg>
                Chat Box
            </a>
            <a class="nav-item" href="/FileManager">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                </svg>
                File Manager
            </a>
            <a class="nav-item" href="/Contact">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                </svg>
                Contacts
            </a>
            <a class="nav-item" href="/Calendar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                Calendar
            </a>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="content">

            <!-- Stat Cards -->
            <div class="stats-grid">
                <div class="stat-card purple">
                    <div class="stat-top">
                        <div>
                            <div class="stat-num">649<sup>+</sup></div>
                            <div class="stat-label">Item Delivered</div>
                        </div>
                        <div class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="9" cy="21" r="1" />
                                <circle cx="20" cy="21" r="1" />
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                            </svg>
                        </div>
                    </div>
                    <div class="stat-change">+23.4%</div>
                </div>

                <div class="stat-card blue">
                    <div class="stat-top">
                        <div>
                            <div class="stat-num">114<sup>+</sup></div>
                            <div class="stat-label">Refund Request</div>
                        </div>
                        <div class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
                                <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z" />
                                <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" />
                            </svg>
                        </div>
                    </div>
                    <div class="stat-change">+14.7%</div>
                </div>

                <div class="stat-card pink">
                    <div class="stat-top">
                        <div>
                            <div class="stat-num">98<sup>+</sup></div>
                            <div class="stat-label">Cancelled Orders</div>
                        </div>
                        <div class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                            </svg>
                        </div>
                    </div>
                    <div class="stat-change">-12.9%</div>
                </div>

                <div class="stat-card orange">
                    <div class="stat-top">
                        <div>
                            <div class="stat-num">208<sup>+</sup></div>
                            <div class="stat-label">New Users</div>
                        </div>
                        <div class="stat-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                        </div>
                    </div>
                    <div class="stat-change">+13.6%</div>
                </div>
            </div>

            <!-- Chart -->
            <div class="chart-card">
                <div class="chart-header">
                    <span class="chart-title">Sales Update</span>
                    <div class="chart-tabs">
                        <div class="tab" onclick="switchTab(this,'daily')">Daily</div>
                        <div class="tab" onclick="switchTab(this,'weekly')">Weekly</div>
                        <div class="tab active" onclick="switchTab(this,'monthly')">Monthly</div>
                    </div>
                </div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#4e8ef7"></div>
                        Income
                    </div>
                    <div class="legend-item">
                        <div class="legend-dot" style="background:#2dcca7"></div>
                        Expenses
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>

        </main>
    </div>

    <script>
        const chartData = {
            monthly: {
                labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
                income:   [30, 55, 70, 65, 85, 75, 60, 70, 90, 75, 95, 80],
                expenses: [20, 35, 55, 50, 40, 45, 35, 40, 45, 38, 50, 42]
            },
            weekly: {
                labels: ['Hf1','Hf2','Hf3','Hf4','Hf5','Hf6','Hf7','Hf8'],
                income:   [18, 25, 30, 22, 35, 28, 40, 33],
                expenses: [10, 15, 20, 18, 22, 17, 25, 19]
            },
            daily: {
                labels: ['Pzt','Sal','Çar','Per','Cum','Cmt','Paz'],
                income:   [5, 8, 6, 9, 7, 4, 3],
                expenses: [3, 5, 4, 6, 5, 2, 2]
            }
        };

        const ctx = document.getElementById('salesChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartData.monthly.labels,
                datasets: [
                    {
                        label: 'Income',
                        data: chartData.monthly.income,
                        borderColor: '#4e8ef7',
                        backgroundColor: 'rgba(78,142,247,0.1)',
                        tension: 0.45, fill: true, pointRadius: 0, borderWidth: 2.5
                    },
                    {
                        label: 'Expenses',
                        data: chartData.monthly.expenses,
                        borderColor: '#2dcca7',
                        backgroundColor: 'rgba(45,204,167,0.08)',
                        tension: 0.45, fill: true, pointRadius: 0, borderWidth: 2.5
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { mode: 'index', intersect: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11 }, color: '#9ca3af' }
                    },
                    y: {
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { font: { size: 11 }, color: '#9ca3af', callback: v => v + '$' },
                        beginAtZero: true
                    }
                }
            }
        });

        function switchTab(el, period) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            const d = chartData[period];
            chart.data.labels = d.labels;
            chart.data.datasets[0].data = d.income;
            chart.data.datasets[1].data = d.expenses;
            chart.update();
        }

        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', () => {
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                item.classList.add('active');
            });
        });
    </script>
</body>
</html>
